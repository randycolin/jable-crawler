def auto_tag(tag):
    """自动将中文标签转为英文slug，原文保留"""
    if not tag:
        return tag
    # 先查完整匹配
    if tag in TAG_MAP:
        return TAG_MAP[tag]
    # 查部分匹配：输入包含中文标签名
    for cn, en in TAG_MAP.items():
        if cn in tag or tag in cn:
            return en
    return tag

