            update_download_progress(vid, percent, speed, eta, 'downloading')

        success, path, size, extra = fast_download_video(video, cb, concurrency=segment_concurrency)
        if success:
            result['downloaded'] += 1
            if qid:
                update_queue_status(qid, 'done')
            mark_downloaded(row['id'], path, size)
            update_download_progress(row['id'], 100, '完成', '', 'done')
            console.print(f"  [green]✓ {os.path.basename(path)}[/green]")
        else:
            result['failed'] += 1
            status = 'skipped' if any(x in str(extra) for x in ['跳过', '不可下载', 'data-src']) else 'failed'
            if qid:
                update_queue_status(qid, status, str(extra))
            update_download_progress(row['id'], 0, '', str(extra), status)
            console.print(f"  [red]✗ {extra}[/red]")
    console.print(f"[green]✓ 完成：下载 {result['downloaded']}，失败 {result['failed']}，跳过已下载 {result['already_done']}、已在队列 {result['already_queued']}、重复 {result['duplicates']}[/green]")
    return result


