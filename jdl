    cmd = sys.argv[1]

    if cmd == 'crawl':
        raw_tag = sys.argv[2] if len(sys.argv) > 2 else 'pantyhose'
        tag = auto_tag(raw_tag)
        if tag != raw_tag:
            print(f"自动识别: {raw_tag} → {tag}")
