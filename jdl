def _porn91_video_key(video):
    """91 视频唯一键：优先 code，其次 url。"""
    code = (video.get('code') or '').strip().lower()
    if code:
        return f"code:{code}"
    return f"url:{(video.get('url') or '').strip().lower()}"


def _find_existing_porn91_video(video):
    """按 code/url 查已存在的 91 记录。"""
    conn = get_conn()
    try:
        if video.get('url'):
            row = conn.execute("SELECT * FROM videos WHERE site='91porny' AND url=? LIMIT 1", (video.get('url'),)).fetchone()
            if row:
                return dict(row)
        if video.get('code'):
            row = conn.execute("SELECT * FROM videos WHERE site='91porny' AND code=? LIMIT 1", (video.get('code'),)).fetchone()
            if row:
                return dict(row)
        return None
    finally:
        conn.close()


def _has_active_queue(video_id):
    """是否已经在待下载/下载中队列。"""
    conn = get_conn()
    try:
        row = conn.execute(
            "SELECT status FROM download_queue WHERE video_id=? AND status IN ('pending','downloading','retrying') LIMIT 1",
            (video_id,)
        ).fetchone()
        return bool(row)
    finally:
        conn.close()


