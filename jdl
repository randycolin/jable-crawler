def show_queue_status():
    """查看队列状态（含后台进度）"""
    if not is_daemon_running():
        recovered = recover_incomplete_downloads(reason='daemon is not running; recovered stale downloading task')
        if recovered.get('pending') or recovered.get('failed'):
            console.print(f"[yellow]已回收残留下载任务：重新排队 {recovered['pending']}，标记失败 {recovered['failed']}[/yellow]")

    pending = get_queue(status='pending')
    downloading = get_queue(status='downloading')
    done = get_queue(status='done')
    failed = get_queue(status='failed')

    table = Table(title="下载队列状态", box=box.ROUNDED)
    table.add_column("状态", style="bold", width=14)
    table.add_column("数量", style="green")
    table.add_column("详情", style="dim")

    table.add_row("[cyan]待下载[/cyan]", str(len(pending)), "")
    table.add_row("[yellow]下载中[/yellow]", str(len(downloading)), "")
    table.add_row("[green]已完成[/green]", str(len(done)), "")
    table.add_row("[red]失败[/red]", str(len(failed)), "")

    # 后台实时进度（SQLite跨进程可见）
    progress_rows = get_download_progress()
    active_progress = [p for p in progress_rows if p.get('status') in ('downloading', 'retrying')]
    if active_progress:
        pnl = "\n[bold cyan]实时下载进度:[/bold cyan]"
        for info in active_progress[:10]:
            pnl += f"\n  #{info['video_id']}: [green]{info['percent']}%[/green] | {info['speed']} | ETA:{info['eta']} | {info['status']}"
        console.print(pnl)

    console.print(table)

    if failed:
        conn = get_conn()
        rows = conn.execute(
            "SELECT dq.error_msg, v.code FROM download_queue dq JOIN videos v ON dq.video_id=v.id WHERE dq.status='failed' LIMIT 5"
        ).fetchall()
        conn.close()
        for r in rows:
            console.print(f"  [dim]{r['code']}: {r['error_msg']}[/dim]")

    # 操作
    if pending:
        s = Prompt.ask("[s]启动下载 [c]清空失败 [q]返回", default="q")
        if s == 's':
            bg = Confirm.ask("后台下载？", default=True)
            if bg:
                if not is_daemon_running():
                    start_background_daemon()
                console.print("[green]后台下载已启动[/green]")
            else:
                start_queue_download()
        elif s == 'c':
            conn = get_conn()
            conn.execute("DELETE FROM download_queue WHERE status='failed'")
            conn.commit()
            conn.close()
            console.print("[green]已清空失败记录[/green]")
    elif is_daemon_running():
        s = Prompt.ask("[s]查看实时进度 [q]返回", default="q")
        if s == 's':
            progress = get_download_progress()
            for info in progress:
                print(f"  #{info['video_id']}: {info['percent']}% | {info['speed']} | ETA:{info['eta']} | {info['status']}")


def start_queue_download():
    """启动队列下载"""
    queue = get_queue(status='pending', limit=10000)
    if not queue:
        console.print("[yellow]队列为空[/yellow]")
        return

    console.print(f"[green]开始下载队列 ({len(queue)}个待下载)[/green]")
    console.print("[dim]按 Ctrl+C 停止[/dim]")
    stop_event.clear()

    for i, item in enumerate(queue, 1):
        if stop_event.is_set():
            console.print("[yellow]已停止[/yellow]")
            break

        video = {
            'id': item['video_id'],
            'url': item['url'],
            'code': item['code'],
            'title': item['title'],
            'tags': item['tags'],
        }

        console.print(f"\n[{i}/{len(queue)}] {video['code']} - {video['title'][:30]}")
        update_queue_status(item['id'], 'downloading')

        with Progress(
            SpinnerColumn(), BarColumn(), TextColumn("{task.fields[info]}"),
            console=console
        ) as progress:
            task = progress.add_task("", total=100, info="...")

            def callback(percent, speed, eta):
                progress.update(task, completed=percent, info=f"{speed}")

            success, path, size, error = fast_download_video(video, callback)

        if success:
            update_queue_status(item['id'], 'done')
            console.print(f"  [green]✓ {os.path.basename(path)}[/green]")
        else:
            update_queue_status(item['id'], 'failed', error)
            console.print(f"  [red]✗ {error}[/red]")

        time.sleep(1)


