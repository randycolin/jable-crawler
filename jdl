def do_download(video):
    """执行下载（多线程、前台或后台）"""
    console.print(f"\n[cyan]下载: {video['code']} - {video['title'][:30]}[/cyan]")
    method = Prompt.ask("模式", choices=["f", "b", "o", "q"], default="f",
                        show_choices=True)
    if method == 'q':
        return
    
    dl_func = fast_download_video  # 默认多线程高速模式
    
    if method == 'b':
        # 后台下载
        add_to_queue(video['id'])
        if not is_daemon_running():
            start_background_daemon()
        console.print(f"[green]✓ 已加入后台下载队列 ({video['code']})[/green]")
        return
    if method == 'o':
        dl_func = download_video  # 旧版ffmpeg模式

    # 前台下载（默认多线程高速）
    with Progress(
        SpinnerColumn(),
        TextColumn("[progress.description]{task.description}"),
        BarColumn(),
        TextColumn("{task.fields[info]}"),
        TimeRemainingColumn(),
        console=console
    ) as progress:
        task = progress.add_task("下载中", total=100, info="获取链接...")

        def callback(percent, speed, eta):
            progress.update(task, completed=percent, info=f"{speed} ETA:{eta}")

        success, path, size, extra = dl_func(video, callback)

    if success:
        size_mb = size / (1024 * 1024)
        console.print(f"[green]✓ 下载完成: {path} ({size_mb:.1f}MB, {extra})[/green]")
    else:
        console.print(f"[red]✗ 下载失败: {extra}[/red]")


