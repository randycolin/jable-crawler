def run_doctor():
    """自检运行环境，返回结构化结果。"""
    init_db()
    checks = {
        'ffmpeg': shutil.which('ffmpeg') is not None,
        'ffprobe': shutil.which('ffprobe') is not None,
        'database': os.path.exists(DB_PATH),
        'download_dir': bool(get_setting('download_dir')),
        'bs4': False,
    }
    try:
        import bs4  # noqa
        checks['bs4'] = True
    except Exception:
        checks['bs4'] = False
    return {'ok': all(checks.values()), 'checks': checks}


def print_doctor():
    result = run_doctor()
    for k, v in result['checks'].items():
        print(f"{k}: {'OK' if v else 'FAIL'}")
    print('overall:', 'OK' if result['ok'] else 'FAIL')
    return result


def retry_failed():
    """把失败队列重置为 pending。"""
    conn = get_conn()
    rows = conn.execute("SELECT id FROM download_queue WHERE status='failed'").fetchall()
    for row in rows:
        conn.execute("UPDATE download_queue SET status='pending', retry_count=0, error_msg='' WHERE id=?", (row['id'],))
    conn.commit()
    conn.close()
    return len(rows)


def clean_temp_files(download_dir=None, pid_file=None):
    """清理临时下载文件和无效PID。"""
    download_dir = download_dir or get_setting('download_dir') or os.path.join(os.path.dirname(os.path.abspath(__file__)), 'videos')
    pid_file = pid_file or DAEMON_PID_FILE
    removed = 0
    freed = 0
    root = Path(download_dir)
    if root.exists():
        patterns = ['*.parts', '*.dlpart', '*.downloading']
        for pattern in patterns:
            for path in root.rglob(pattern):
                try:
                    if path.is_dir():
                        size = sum(p.stat().st_size for p in path.rglob('*') if p.is_file())
                        shutil.rmtree(path)
                    else:
                        size = path.stat().st_size
                        path.unlink()
                    removed += 1
                    freed += size
                except OSError:
                    pass
    if pid_file and os.path.exists(pid_file) and not is_daemon_running():
        try:
            os.remove(pid_file)
            removed += 1
        except OSError:
            pass
    return {'removed': removed, 'freed': freed}


def download_url(url):
    """直接下载视频详情链接，不要求先入库。"""
    try:
        adapter = detect_adapter(url)
    except Exception as e:
        return False, '', 0, str(e)

    if adapter.site == 'jable':
        m = re.search(r'/videos/([^/]+)/?', url)
        if not m:
            return False, '', 0, '无效Jable视频链接'
        code = m.group(1).upper()
        # Jable 保持旧路径，便于现有测试和旧调用 monkeypatch。
        detail = fetch_video_detail(url)
    else:
        detail = adapter.fetch_video_detail(url)
        if detail.get('is_downloadable') is False:
            return False, '', 0, detail.get('skip_reason') or '内容不可下载'
        code = adapter.extract_code(url) if hasattr(adapter, 'extract_code') else adapter.site

    video = {
        'id': 0,
        'site': adapter.site,
        'url': url,
        'code': code,
        'title': detail.get('title') or code,
        'tags': detail.get('tags', adapter.site),
    }
    return fast_download_video(video)


def daemon_cli(action):
    if action == 'start':
        ok = start_background_daemon()
        print('started' if ok else 'failed')
    elif action == 'stop':
        stop_background_daemon()
        print('stopped')
    elif action == 'status':
        print('running' if is_daemon_running() else 'stopped')
    elif action == 'logs':
        log_path = os.path.join(os.path.dirname(os.path.abspath(__file__)), 'logs', 'jdl.log')
        if os.path.exists(log_path):
            with open(log_path, encoding='utf-8') as f:
                lines = f.readlines()[-50:]
            print(''.join(lines), end='')
        else:
            print('no logs')
    else:
        print('用法: jdl daemon [start|stop|status|logs]')

def cli_mode():
