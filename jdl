def resume_crawl():
    """继续未完成的爬取"""
    progress_list = get_crawl_progress()
    incomplete = [p for p in progress_list if not p['completed']]

    if not incomplete:
        console.print("[yellow]没有未完成的爬取任务[/yellow]")
        return

    table = Table(title="未完成的爬取", box=box.ROUNDED)
    table.add_column("#", style="dim", width=4)
    table.add_column("标签", style="cyan")
    table.add_column("已爬页数", style="green")
    table.add_column("已发现", style="yellow")

    for i, p in enumerate(incomplete, 1):
        table.add_row(str(i), p['tag_name'] or p['tag'], str(p['last_page']), str(p['total_videos']))

    console.print(table)
    idx = Prompt.ask("选择继续哪个（a=全部）", default="1")

    if idx.lower() == 'a':
        targets = incomplete
    else:
        try:
            targets = [incomplete[int(idx) - 1]]
        except (ValueError, IndexError):
            return

    for t in targets:
        tag = t['tag']
        if tag.startswith('cat:'):
            crawl_category(tag[4:], t['tag_name'], stop_event=stop_event)
        else:
            crawl_tag(tag, t['tag_name'], stop_event=stop_event)


