def crawl_by_tag():
    """按标签爬取"""
    console.print("\n[dim]正在获取标签列表...[/dim]")
    tags = fetch_tags()

    if not tags:
        # 手动输入（支持中文）
        tag_input = Prompt.ask("输入标签（支持中文，如 黑丝）")
        if not tag_input:
            return
        eng_slug = auto_tag(tag_input)
        if eng_slug != tag_input:
            console.print(f"[dim]自动识别: {tag_input} → {eng_slug}[/dim]")
        tags = [{'slug': eng_slug, 'name': tag_input}]
    else:
        # 显示热门标签
        table = Table(title="热门标签", box=box.ROUNDED)
        table.add_column("#", style="dim", width=4)
        table.add_column("标签", style="cyan")
        table.add_column("Slug", style="dim")

        for i, t in enumerate(tags[:30], 1):
            table.add_row(str(i), t['name'], t['slug'])

        console.print(table)
        idx = Prompt.ask("\n选择编号（或直接输入slug）", default="1")

        try:
            idx_num = int(idx) - 1
            if 0 <= idx_num < len(tags):
                selected = tags[idx_num]
            else:
                return
        except ValueError:
            eng_slug = auto_tag(idx)
            if eng_slug != idx:
                console.print(f"[dim]自动识别: {idx} → {eng_slug}[/dim]")
            selected = {'slug': eng_slug, 'name': idx}

        tags = [selected]

    tag = tags[0]
    console.print(f"\n[green]开始爬取: {tag['name']} ({tag['slug']})[/green]")
    stop_event.clear()

    with Progress(
        SpinnerColumn(),
        TextColumn("[progress.description]{task.description}"),
        BarColumn(),
        TextColumn("{task.fields[info]}"),
        console=console
    ) as progress:
        task = progress.add_task(f"爬取 {tag['name']}", total=None, info="准备中...")

        def callback(page, total, new, error=None):
            if error:
                progress.update(task, info=f"[red]错误: {error}[/red]")
            else:
                progress.update(task, info=f"第{page}页 | 发现{total}个 | 新增{new}个")

        result = crawl_tag(tag['slug'], tag['name'], callback=callback, stop_event=stop_event)

    console.print(f"\n[green]✓ 完成！共{result['pages']}页，发现{result['total_found']}个视频，新增{result['new_added']}个[/green]")


